{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nexus Input Engine — user config",
  "type": "object",
  "required": ["account", "collections", "projects_canon"],
  "properties": {
    "account": {"type": "string", "description": "Your handle on the primary platform"},
    "instagram_saved_url_template": {"type": "string"},
    "dashboard_file": {"type": "string", "default": "DASHBOARD.html"},
    "collections": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "properties": {
          "name": {"type": "string"},
          "source": {"type": "string", "description": "instagram | x | <custom>"},
          "saved_collection_id": {"type": ["string", "null"]},
          "url": {"type": ["string", "null"]}
        }
      }
    },
    "projects_canon": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["term", "axis"],
        "properties": {
          "term": {"type": "string"},
          "axis": {"type": "string", "enum": ["system_project", "content_channel", "personal"]},
          "aliases": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}
