{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Nexus Input Engine — onboarding answers",
  "description": "Structured answers gathered by docs/SETUP.md; map to config.json.",
  "type": "object",
  "required": ["account", "lists", "projects"],
  "properties": {
    "account": {"type": "string", "description": "Your primary-platform handle"},
    "lists": {
      "type": "array", "minItems": 1,
      "description": "Saved lists/collections to track",
      "items": {
        "type": "object",
        "required": ["name", "source"],
        "properties": {
          "name": {"type": "string", "pattern": "^[a-z0-9-]+$"},
          "source": {"type": "string", "description": "instagram | x | <custom>"},
          "saved_collection_id": {"type": ["string", "null"], "description": "Instagram: number in the saved-list URL"},
          "url": {"type": ["string", "null"], "description": "X/custom: the list URL"}
        }
      }
    },
    "projects": {
      "type": "array", "minItems": 1,
      "description": "Destinations and their axes",
      "items": {
        "type": "object",
        "required": ["term", "axis"],
        "properties": {
          "term": {"type": "string"},
          "axis": {"type": "string", "enum": ["system_project", "content_channel", "personal"]},
          "aliases": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "cadence": {"type": "string", "description": "How often you run collection+cataloging (free text)"},
    "gates": {
      "type": "object",
      "properties": {
        "weekly_adopt_cap": {"type": "integer", "minimum": 1, "default": 3,
          "description": "Enforced in engine/adopt.py WEEK_CAP; default 3"},
        "sensitive_marked_by": {"type": "string", "default": "ficha frontmatter `sensivel:`",
          "description": "How sensitive items are flagged (routes to personal)"}
      }
    }
  }
}
